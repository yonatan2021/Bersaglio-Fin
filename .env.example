# Bersaglio-Fin — Environment Variables
# Copy to .env and fill in your values

# ─── Telegram Bot (required for bot) ──────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
# Comma-separated Telegram user IDs allowed to use the bot
ALLOWED_TELEGRAM_IDS=123456789,987654321

# ─── Database (optional — defaults to local encrypted SQLite) ──────
# SQLite default path: ~/Library/Application Support/Asher/database.db (macOS)
# Uncomment to use a custom path or PostgreSQL:
# DATABASE_URL=sqlite:///custom/path/to/database.db
# DATABASE_URL=postgres://user:password@localhost:5432/bersaglio

# PostgreSQL (alternative to DATABASE_URL — use one or the other)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=bersaglio
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_SSL=false

# ─── Node ──────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Notes ─────────────────────────────────────────────────────────
# Encryption key is NOT stored here — you enter it interactively on startup.
# Never put real bank credentials in this file or any env var.
# Bank credentials are managed via: npm run ingest-creds
